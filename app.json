{
  "expo": {
    "name": "Haarlos",
    "slug": "almand-app",
    "icon": "./assets/almand.png",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "sdkVersion": "54.0.0",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.almandapp",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/almand.png",
        "backgroundColor": "#ffffff"
      }
    },
    "splash": {
      "image": "./assets/almand.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/notification.mp3"
          ]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow access to scan QR codes and barcodes"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "50cd240f-bc18-424b-b3f5-3d86bdf383a6"
      }
    }
  }
}
